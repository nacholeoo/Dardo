# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true&connection_limit=1&pool_timeout=20"

# Authentication
JWT_SECRET="generate_with_node_crypto_randomBytes_32_hex"
ADMIN_PASSWORD_HASH="bcrypt_hash_of_admin_password"

# Air Intra API
AIR_INTRA_API_TOKEN="your_air_intra_api_token"
AIR_INTRA_API_URL="https://api.air-intra.com/v2"

# MercadoLibre OAuth
ML_CLIENT_ID="your_ml_client_id"
ML_CLIENT_SECRET="your_ml_client_secret"
ENCRYPTION_KEY="generate_with_node_crypto_randomBytes_32_hex"

# Email Notifications (Resend)
RESEND_API_KEY="your_resend_api_key"
NOTIFICATION_EMAIL="admin@yourdomain.com"

# Cron Protection
CRON_SECRET="generate_with_node_crypto_randomBytes_32_hex"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
